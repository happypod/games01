{
  "name": "ember-idle-rpg",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:soak": "vitest run src/game/debugSimulator.test.ts",
    "test:soak:update": "npx --yes tsx@4.20.6 tools/update-debug-soak.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:assets": "playwright test --config playwright.assets.config.ts",
    "test:e2e:visual": "node tools/run-visual-regression.mjs",
    "test:e2e:visual:update": "node tools/run-visual-regression.mjs --update-snapshots",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:assets": "node --test tools/assets/validate-manifest.test.mjs",
    "assets:validate": "node tools/assets/validate-manifest.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "verify:code": "npm run lint && npm run typecheck && npm run test && npm run test:assets && npm run assets:validate && npm run build",
    "verify": "npm run verify:code && npm run test:e2e && npm run test:e2e:assets && npm run test:e2e:visual"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.3.1",
    "@fortawesome/free-solid-svg-icons": "^7.3.1",
    "@fortawesome/react-fontawesome": "^3.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
